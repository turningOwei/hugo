[
  {
    "source": "**/*.@(css|js)",
    "headers": {
      "Cache-Control": "public, max-age=31536000, immutable"
    }
  },
  {
    "source": "**/*.@(woff|woff2|ttf|eot|svg|png|jpg|jpeg|gif|ico|webp)",
    "headers": {
      "Cache-Control": "public, max-age=31536000, immutable"
    }
  },
  {
    "source": "**/*.@(html|xml|json|txt)",
    "headers": {
      "Cache-Control": "public, max-age=0, must-revalidate"
    }
  },
  {
    "source": "**",
    "headers": {
      "X-Content-Type-Options": "nosniff",
      "X-Frame-Options": "DENY",
      "X-XSS-Protection": "0"
    }
  }
]
